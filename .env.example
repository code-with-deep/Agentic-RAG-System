# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LLM PROVIDER (choose one: gemini or groq)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
LLM_PROVIDER=gemini

# Google Gemini API Key (free tier available at aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key (free tier at console.groq.com) — alternative to Gemini
GROQ_API_KEY=your_groq_api_key_here

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# WEB SEARCH FALLBACK
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Tavily API Key (free tier at tavily.com — recommended)
TAVILY_API_KEY=your_tavily_api_key_here

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DATABASE PATHS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
CHROMA_DB_PATH=./data/chromadb
SQLITE_DB_PATH=./data/sqlite/agentic_rag.db

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# MODEL CONFIGURATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
EMBEDDING_MODEL=all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AGENTIC PIPELINE THRESHOLDS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
HALLUCINATION_THRESHOLD=0.2
ROUTING_CONFIDENCE_THRESHOLD=0.7
MAX_RETRIEVAL_RETRIES=3
MAX_GENERATION_RETRIES=2
TOP_K_RETRIEVAL=20
TOP_K_FINAL=5

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# FALLBACK SETTINGS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
ENABLE_WEB_SEARCH=True
ENABLE_LLM_FALLBACK=True

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# MISC
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
ANONYMIZED_TELEMETRY=False
